integrator  = md
dt          = 0.002
nsteps      = 25000
nstxout-compressed = 5000
nstlog      = 5000
nstenergy   = 5000
cutoff-scheme = Verlet
coulombtype = PME
rcoulomb    = 1.0
vdwtype     = Cut-off
rvdw        = 1.0
tcoupl      = V-rescale
tc-grps     = System
tau-t        = 0.1
ref-t        = 100
pcoupl      = no
pbc         = xyz
constraints = h-bonds
constraint-algorithm = LINCS

gen-vel = yes
gen-temp = 100
