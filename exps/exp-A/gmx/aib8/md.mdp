integrator  = md
dt          = 0.002
nsteps      = 100000000
nstxout-compressed = 50000
nstlog      = 10000
nstenergy   = 10000
cutoff-scheme = Verlet
coulombtype = PME
rcoulomb    = 1.0
vdwtype     = Cut-off
rvdw        = 1.0
tcoupl      = V-rescale
tc-grps     = System
tau-t        = 0.1
ref-t        = 310
pcoupl      = no
pbc         = xyz
constraints = h-bonds
constraint-algorithm = LINCS
