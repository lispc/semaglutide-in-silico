integrator  = md
dt          = 0.002
nsteps      = 150000
nstxout-compressed = 5000
nstlog      = 5000
nstenergy   = 5000
cutoff-scheme = Verlet
coulombtype = PME
rcoulomb    = 1.0
vdwtype     = Cut-off
rvdw        = 1.0
tcoupl      = V-rescale
tc-grps     = System
tau-t        = 0.1
ref-t        = 310
pcoupl      = C-rescale
pcoupltype  = isotropic
tau-p       = 2.0
ref-p       = 1.0
compressibility = 4.5e-5
refcoord-scaling = com
pbc         = xyz
constraints = h-bonds
constraint-algorithm = LINCS
