source leaprc.protein.ff14SB
source leaprc.gaff2
source leaprc.water.tip3p
complex = loadpdb complex_diacid.pdb
loadmol2 c18_diacid_fa3.mol2
solvatebox complex TIP3PBOX 10.0
addions complex Na+ 0
addions complex Cl- 0
charge complex
saveamberparm complex c18_diacid.prmtop c18_diacid.inpcrd
savepdb complex c18_diacid_tleap.pdb
quit
