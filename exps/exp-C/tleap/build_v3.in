source leaprc.protein.ff14SB
source leaprc.gaff2
source leaprc.water.tip3p
FAH = loadmol2 c18_monoacid_fa3.mol2
complex = loadpdb complex_mono.pdb
solvatebox complex TIP3PBOX 10.0
addions complex Na+ 0
addions complex Cl- 0
charge complex
saveamberparm complex c18_monoacid.prmtop c18_monoacid.inpcrd
savepdb complex c18_monoacid_tleap.pdb
quit
